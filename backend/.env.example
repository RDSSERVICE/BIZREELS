# Server Config
PORT=8001
NODE_ENV=development

# MongoDB
MONGO_URL=mongodb://localhost:27017/emergent
DB_NAME=emergent

# Security
JWT_SECRET=dev-secret-change-in-production
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# MSG91 (OTP & SMS notifications)
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_TEMPLATE_ID=your-template-id
MSG91_SENDER_ID=your-sender-id
MSG91_DEV_MODE=true

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_DEV_MODE=true

# Razorpay
RAZORPAY_KEY_ID=your-key-id
RAZORPAY_KEY_SECRET=your-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
RAZORPAY_DEV_MODE=true

# Google (OAuth & AI)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_AI_API_KEY=your-gemini-ai-key

# Admin Defaults (Dev-mode backdoors & fallbacks)
ADMIN_PHONE=9999999999
ADMIN_NAME=Admin
ALLOW_DEV_ADMIN_LOGIN=true
DEV_ADMIN_OVERRIDE_TOKEN=your-dev-token
