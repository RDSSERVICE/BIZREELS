# ============================================
# BizReels Frontend Environment Configuration Example
# ============================================

# Google Maps API Key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Backend URL Configuration
# Example production URL: https://api.yourdomain.com
VITE_BACKEND_URL=https://your-backend-api-domain.com

# Explicit API Base URL override (Optional)
VITE_API_URL=https://your-backend-api-domain.com/api/v1

# Realtime Socket Server URL (Optional)
VITE_SOCKET_URL=https://your-backend-api-domain.com

# Google OAuth Client ID (Optional)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Cloudinary Storage Configuration (Optional)
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset
